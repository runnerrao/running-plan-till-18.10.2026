function StrengthDetail({ sKey, note }) {
  const s = STRENGTH[sKey];
  if (!s) return null;
  return (
    <div style={{ marginTop: 10, padding: "12px 14px", background: "#c4441410", border: "1px solid #c4441430", borderRadius: 8 }}>
      <div style={{ fontSize: "0.72rem", color: "#c44", fontWeight: 700, marginBottom: 2 }}>{s.label}</div>
      <div style={{ fontSize: "0.68rem", color: "#888", marginBottom: 8 }}>{s.duration} · {s.focus}</div>
      {note && <div style={{ fontSize: "0.68rem", color: "#f0a030", marginBottom: 8 }}>⚠️ {note}</div>}
      {s.exercises.map((ex, i) => (
        <div key={i} style={{ display: "flex", justifyContent: "space-between", marginBottom: 4, gap: 8 }}>
          <div style={{ fontSize: "0.73rem", color: "#ddd" }}>{ex.name}</div>
          <div style={{ fontSize: "0.68rem", color: "#888", textAlign: "right", minWidth: 80 }}>{ex.sets}</div>
        </div>
      ))}
      {s.exercises.map((ex, i) => ex.note ? (
        <div key={`n${i}`} style={{ fontSize: "0.65rem", color: "#666", marginBottom: 2, paddingLeft: 4 }}>· {ex.name}: {ex.note}</div>
      ) : null)}
    </div>
  );
}

function SpinDetail({ sKey }) {
  const s = SPIN[sKey];
  if (!s) return null;
  return (
    <div style={{ marginTop: 10, padding: "12px 14px", background: "#00D4FF10", border: "1px solid #00D4FF30", borderRadius: 8 }}>
      <div style={{ fontSize: "0.72rem", color: "#00D4FF", fontWeight: 700, marginBottom: 2 }}>{s.label}</div>
      <div style={{ fontSize: "0.68rem", color: "#888", marginBottom: 6 }}>{s.duration} · {s.intensity}</div>
      <div style={{ fontSize: "0.7rem", color: "#aaa", marginBottom: 8 }}>{s.detail}</div>
      {s.structure.map((seg, i) => (
        <div key={i} style={{ display: "flex", gap: 10, marginBottom: 4 }}>
          <div style={{ fontSize: "0.67rem", color: "#00D4FF", minWidth: 70 }}>{seg.segment}</div>
          <div style={{ fontSize: "0.68rem", color: "#bbb" }}>{seg.desc}</div>
        </div>
      ))}
    </div>
  );
}

function DayRow({ d, accent }) {
  const [open, setOpen] = useState(false);
  const ds = dayTypeStyle[d.type] || dayTypeStyle.rest;
  const hasDetail = d.detail || d.ref || d.strengthRef;
  return (
    <div onClick={() => hasDetail && setOpen(!open)}
      style={{ background: open ? ds.bg : "transparent", border: `1px solid ${open ? ds.color + "40" : "#1e1e1e"}`, borderRadius: 6, padding: "8px 10px", marginBottom: 4, cursor: hasDetail ? "pointer" : "default", transition: "all 0.15s" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
        <div style={{ fontSize: "0.62rem", color: "#444", minWidth: 28, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.06em" }}>{d.day}</div>
        <div style={{ fontSize: "0.75rem" }}>{d.icon}</div>
        <div style={{ flex: 1 }}>
          <div style={{ fontSize: "0.75rem", color: d.type === "rest" ? "#555" : "#ddd", fontWeight: 500 }}>
            {d.label || (d.ref && SPIN[d.ref]?.label) || (d.ref && STRENGTH[d.ref]?.label)}
            {d.strengthRef && <span style={{ color: "#c44", marginLeft: 6, fontSize: "0.65rem" }}>+ {STRENGTH[d.strengthRef]?.label.split(" — ")[0]}</span>}
          </div>
          {d.pace && <div style={{ fontSize: "0.67rem", color: accent, marginTop: 1, fontFamily: "'Bebas Neue', monospace", letterSpacing: "0.05em" }}>⏱ {d.pace}</div>}
          {d.km && <div style={{ fontSize: "0.62rem", color: "#555", marginTop: 1 }}>{d.km} km</div>}
        </div>
        <div style={{ fontSize: "0.62rem", fontWeight: 700, color: ds.color, background: ds.bg, border: `1px solid ${ds.color}30`, borderRadius: 3, padding: "1px 6px", letterSpacing: "0.08em" }}>{ds.label}</div>
        {hasDetail && <div style={{ color: "#444", fontSize: "0.7rem", transition: "transform 0.2s", transform: open ? "rotate(180deg)" : "rotate(0)" }}>▼</div>}
      </div>
      {open && (
        <div style={{ marginTop: 8, paddingTop: 8, borderTop: "1px solid #1e1e1e" }}>
          {d.detail && <div style={{ fontSize: "0.73rem", color: "#aaa", marginBottom: 8, lineHeight: 1.5 }}>{d.detail}</div>}
