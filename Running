          {d.ref && STRENGTH[d.ref] && <StrengthDetail sKey={d.ref} note={d.note} />}
          {d.strengthRef && <StrengthDetail sKey={d.strengthRef} note={d.note} />}
        </div>
      )}
    </div>
  );
}

function WeekCard({ w, accent }) {
  const [open, setOpen] = useState(false);
  const t = typeColors[w.type];
  const runDays = w.days.filter(d => d.type === "run" || d.type === "run+strength").length;
  const gymDays = w.days.filter(d => d.type === "strength" || d.type === "run+strength").length;
  const spinDays = w.days.filter(d => d.type === "spin").length;
  return (
    <div style={{ background: t.bg, border: `1px solid ${open ? accent : t.border}`, borderRadius: 10, marginBottom: 8, overflow: "hidden", transition: "border-color 0.2s" }}>
      <div onClick={() => setOpen(!open)} style={{ padding: "12px 16px", cursor: "pointer", display: "flex", justifyContent: "space-between", alignItems: "center", gap: 12 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12, flex: 1 }}>
          <div style={{ fontFamily: "'Bebas Neue', sans-serif", fontSize: "1.5rem", color: accent, minWidth: 48, lineHeight: 1 }}>W{w.week}</div>
          <div>
            <div style={{ fontSize: "0.73rem", color: "#ccc", fontWeight: 600 }}>{w.dates}</div>
            <div style={{ fontSize: "0.67rem", color: "#666", marginTop: 2 }}>{w.keyFocus}</div>
            <div style={{ display: "flex", gap: 8, marginTop: 4 }}>
              {runDays > 0 && <span style={{ fontSize: "0.58rem", color: "#6ec96e", background: "#6ec96e15", border: "1px solid #6ec96e30", borderRadius: 3, padding: "1px 5px" }}>🏃 {runDays}x run</span>}
              {gymDays > 0 && <span style={{ fontSize: "0.58rem", color: "#c44", background: "#c4441415", border: "1px solid #c4441430", borderRadius: 3, padding: "1px 5px" }}>🏋️ {gymDays}x gym</span>}
              {spinDays > 0 && <span style={{ fontSize: "0.58rem", color: "#00D4FF", background: "#00D4FF15", border: "1px solid #00D4FF30", borderRadius: 3, padding: "1px 5px" }}>🚴 {spinDays}x spin</span>}
            </div>
          </div>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          <div style={{ background: t.badge + "22", border: `1px solid ${t.badge}44`, borderRadius: 4, padding: "2px 8px", fontSize: "0.62rem", color: t.badge, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.1em" }}>{t.label}</div>
          <div style={{ fontFamily: "'Bebas Neue', sans-serif", fontSize: "1.2rem", color: "#fff", minWidth: 55, textAlign: "right" }}>{w.km} km</div>
          <div style={{ color: "#444", fontSize: "0.7rem", transition: "transform 0.2s", transform: open ? "rotate(180deg)" : "rotate(0)" }}>▼</div>
        </div>
      </div>
      {open && (
        <div style={{ padding: "0 12px 12px" }}>
          {w.days.map((d, i) => <DayRow key={i} d={d} accent={accent} />)}
        </div>
      )}
    </div>
  );
}

function Countdown({ targetDate, color }) {
  const [days, setDays] = useState(0);
  useEffect(() => {
    const update = () => setDays(Math.max(0, Math.ceil((targetDate - new Date()) / 86400000)));
    update();
    const t = setInterval(update, 60000);
    return () => clearInterval(t);
  }, [targetDate]);
  return (
    <div style={{ textAlign: "center" }}>
      <div style={{ fontSize: "2.5rem", fontWeight: 900, color, fontFamily: "'Bebas Neue', sans-serif", lineHeight: 1 }}>{days}</div>
      <div style={{ fontSize: "0.58rem", color: "#666", letterSpacing: "0.15em", textTransform: "uppercase" }}>days</div>
    </div>
  );
}

